# Auth0 – create a Machine-to-Machine / Regular Web App in Auth0 dashboard
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://ahpi-api.example.com

# Redis – Render provides a Redis add-on with REDIS_URL env var
REDIS_URL=redis://localhost:6379

# Rate limiting (optional overrides)
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# CORS – comma-separated origins (or * for development)
CORS_ORIGINS=["http://localhost:3000","https://ahpi.example.com"]

# App
APP_ENV=development
LOG_LEVEL=INFO
